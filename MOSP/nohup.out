find ../Frinhani/Instances -name '*.txt' | while read file; do \
	echo "==> Executando $file..."; \
	./mainMOSP "$file" --TEMP_INIT 0.01 --TEMP_FIM 10 --N_REPLICAS 5 --MCL 600 --TEMP_DIST 2 --MOV_TYPE 2 --TYPE_UPDATE 0 --READ 1; \
done
